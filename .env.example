# North Hanover Grille - Environment Configuration
# Copy this file to .env and fill in values

# Database (SQLite for development - file based, zero config)
DATABASE_URL="file:./prisma/dev.db"

# Admin Back Door password (change this!)
# Used for simple password-protected admin access
ADMIN_PASSWORD="admin"

# Optional: Public site base URL (for absolute links, PWA, emails later)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Optional future: Cloud storage keys, payment keys, etc.
# UPLOADTHING_SECRET=...
# STRIPE_SECRET_KEY=...
